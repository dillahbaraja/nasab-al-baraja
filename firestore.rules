rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /familyNodes/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /notices/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /admins/{document} {
      allow read, write: if request.auth != null;
    }
  }
}
